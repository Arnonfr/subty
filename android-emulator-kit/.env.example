# ---- Android SDK / Java ----
# Optional if already exported globally
ANDROID_SDK_ROOT=/Users/your-user/.local/android-sdk
JAVA_HOME=/Users/your-user/.local/jdk21

# ---- Emulator profile ----
AVD_NAME=shared_api35
API_LEVEL=35
ABI=arm64-v8a
SYSTEM_IMAGE=google_apis

# ---- Project-specific app launch ----
PROJECT_DIR=/absolute/path/to/your/project
APK_RELATIVE_PATH=app/build/outputs/apk/debug/app-debug.apk
GRADLE_TASK=assembleDebug
APPLICATION_ID=com.example.app
MAIN_ACTIVITY=.MainActivity

# If true, scripts can create the AVD automatically
AUTO_CREATE_AVD=true
